# BigQuery credentials -- one of these two paths:

# Option A: Point to a service account JSON file path
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Option B: Paste the full JSON inline (single line, escaped)
# GCP_SERVICE_ACCOUNT_JSON=

# Default project/dataset (also settable per-request from the UI)
BQ_PROJECT_ID=my-gcp-project
BQ_DATASET_ID=analytics_123456789

# CORS origin for the frontend
FRONTEND_ORIGIN=http://localhost:5173

# ============================================================================
# Optional: AI features (NLQ Ask box, Insight "Explain why", User Profile narrative)
# ============================================================================
# Pick ONE provider. Gemini is recommended -- generous free tier (1500
# requests/day on Flash 2.0). If both are set, Gemini takes priority.
# Without either, the app falls back to template-based explanations
# (still useful, just less rich).

# Option 1: Gemini (recommended for free tier).
# Get a key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...

# Option 2: Anthropic Claude. ~$0.001 per call with Haiku.
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api...

# ============================================================================
# Optional: shared password protection (Phase 9)
# ============================================================================
# Set this if you're running InsightPM on a LAN, on a shared machine, or
# anywhere it could be accidentally accessed. The frontend will require the
# password before any /api call goes through.
#
# Leave empty/unset for local-only personal use (no auth, easier dev flow).
#
# This is shared-secret auth for a single-tenant tool -- not multi-user
# session management. Anyone with the password gets full access.
#
# INSIGHTPM_PASSWORD=your-shared-password-here
